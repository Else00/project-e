{
  "name": "project-e-web",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "biome lint .",
    "fmt": "biome format --write .",
    "fmt-check": "biome format .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "check": "bun run fmt-check && bun run lint && bun run typecheck && bun run coverage && bun run build && bun run e2e"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.23.26",
    "project-e-protocol": "file:vendor/project-e-protocol",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.16",
    "jsdom": "^27.3.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
